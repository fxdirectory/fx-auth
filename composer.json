{
  "name": "fx-auth/microservice-auth",
  "description": "Microservice authentication API using Slim PHP, JWT, and MySQL.",
  "require": {
    "php": "^8.0",
    "slim/slim": "^4.0",
    "slim/psr7": "^1.5",
    "firebase/php-jwt": "^6.0",
    "vlucas/phpdotenv": "^5.0",
    "monolog/monolog": "^3.0",
    "php-di/php-di": "^6.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8080 -t public public/index.php",
    "migrate": "vendor/bin/phinx migrate",
    "rollback": "vendor/bin/phinx rollback -t 0",
    "seed": "vendor/bin/phinx seed:run"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "robmorgan/phinx": "^0.13"
  }
}
